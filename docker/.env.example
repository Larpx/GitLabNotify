# ============================================================================
# GitLabNotify 环境变量配置
# ============================================================================
# 使用方式：复制此文件为 .env 并修改对应值
#   cp .env.example .env
# ============================================================================

# --- 服务端口 ---
# 宿主机映射端口（容器内固定 48581）
HOST_PORT=48581

# --- GitLab Webhook 鉴权 ---
# 在 GitLab 项目 Settings → Webhooks 中配置的 Secret Token
# 必须配置，否则任何人都可以向你的服务发送伪造的 Webhook
GITLAB_WEBHOOK_SECRET=your-gitlab-secret-token

# --- 目标平台 0（默认：企业微信群机器人）---
TARGET_0_NAME=企业微信群机器人
TARGET_0_TYPE=WechatWork
TARGET_0_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=your-key-here
TARGET_0_ENABLED=true

# --- 目标平台 1（可选：钉钉群机器人）---
# TARGET_1_NAME=钉钉群机器人
# TARGET_1_TYPE=DingTalk
# TARGET_1_URL=https://oapi.dingtalk.com/robot/send?access_token=your-token
# TARGET_1_ENABLED=false

# --- 目标平台 2（可选：飞书群机器人）---
# TARGET_2_NAME=飞书群机器人
# TARGET_2_TYPE=Feishu
# TARGET_2_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your-hook-id
# TARGET_2_ENABLED=false

# --- 处理管线配置 ---
# 失败重试次数
PIPELINE_MAX_RETRY=3
# 初始重试延迟（秒，指数退避：5s→10s→20s）
PIPELINE_RETRY_DELAY=5
# 待处理队列容量
PIPELINE_CAPACITY=1000

# --- 持久化 ---
# SQLite 连接字符串（默认使用容器内 /app/data 目录）
# DB_CONNECTION=Data Source=/app/data/gitlabnotify.db

# --- 日志 ---
# 日志级别：Verbose / Debug / Information / Warning / Error / Fatal
LOG_LEVEL=Information
